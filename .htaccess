# Hostinger Deployment .htaccess
# This handles React Router and Node.js API routing via Passenger

RewriteEngine On

# 1. Route /api requests to the Node.js app (server.cjs)
RewriteCond %{REQUEST_URI} ^/api [NC]
RewriteRule ^api/(.*)$ server.cjs/$1 [L]

# 2. Serve static files from the build (dist folder) if they exist
# Note: If you upload the contents of 'dist' directly to the root, 
# you don't need the 'dist/' prefix here.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L]

# 3. Optional: Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
